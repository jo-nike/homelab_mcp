#!/usr/bin/env bash
# Pre-push: full lint, format-check, and test suite.
set -euo pipefail

echo "pre-push: ruff check ..."
uv run ruff check .

echo "pre-push: ruff format --check ..."
uv run ruff format --check .

echo "pre-push: ty check ..."
uv run ty check .

echo "pre-push: pytest ..."
uv run pytest tests/ -q
