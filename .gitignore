.env
__pycache__/
*.pyc
.venv/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Synced data (populated by `make sync-data`, not tracked in git)
data/docs/*
data/stacks/*
data/vault/*
!data/docs/.gitkeep
!data/stacks/.gitkeep
!data/vault/.gitkeep
.claude/worktrees/

# Real knowledge registries are user-generated: run
# `uv run scripts/bootstrap_registries.py` or copy the data/*.example.yaml
# files and edit. Only the examples are tracked.
data/hosts.yaml
data/services.yaml
data/topology.yaml
data/baselines.yaml
