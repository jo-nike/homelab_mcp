# MYSPEED_PASSWORD=your-myspeed-password

# --- Cron Monitoring ---
# HEALTHCHECKS_URL=http://192.168.1.79:8000
# HEALTHCHECKS_API_KEY=

# --- Plex Analytics ---
# TAUTULLI_URL=http://192.168.1.108:8181
# TAUTULLI_API_KEY=

# --- LLM Proxy ---
# LITELLM_URL=http://192.168.1.119:4000
# LITELLM_API_KEY=

# --- Inference Server ---
# LLAMA_SERVER_URL=http://192.168.1.119:8080
# LLAMA_SERVER_API_KEY=

# --- Web Search ---
# SEARXNG_URL=http://192.168.1.79:8890
# fetch_page SSRF policy. Loopback, link-local, and cloud-metadata targets are
# ALWAYS blocked. Private/RFC1918 targets (e.g. LAN admin pages) are allowed
# only when this is true — the default, which preserves LAN-fetch behavior.
# Set to false to also block private targets.
# FETCH_ALLOW_PRIVATE=true

# --- Refresh intervals (seconds) ---
# How often the background loop re-fetches registries and docs. Defaults shown.
# REFRESH_INTERVAL_SECONDS=600
# DOC_REFRESH_INTERVAL_SECONDS=3600

# Transport (stdio or streamable-http)
# MCP_TRANSPORT=stdio
# MCP_PORT=8000
# Reported by /health for deploy verification; CI injects the CalVer+SHA tag.
# APP_VERSION=dev

# OAuth via Authentik (required when MCP_TRANSPORT is streamable-http/sse).
# Public clients (e.g. Claude Cowork) discover the auth server through the
# MCP-spec /.well-known/oauth-protected-resource endpoint, then PKCE against
# Authentik. The MCP server validates the resulting JWT — `audience` must
# equal the OAuth provider's client_id.
# AUTHENTIK_CLIENT_ID=
# Authentik OIDC endpoints. Defaults target auth.example.com; override only when
# redeploying under a different domain.
# AUTHENTIK_ISSUER=https://auth.example.com/application/o/homelab-mcp/
# AUTHENTIK_JWKS_URI=https://auth.example.com/application/o/homelab-mcp/jwks/
# MCP_RESOURCE_BASE_URL=https://mcp.example.com
# Comma-separated CIDRs whose direct connections (no XFF/Real-IP/Via/Forwarded
# and no Origin header) are treated as authenticated via an in-process
# synthetic bearer token. Set explicitly to override; empty disables the
# bypass entirely.
# MCP_TRUSTED_CIDRS=192.168.1.0/24,127.0.0.0/8

# Comma-separated CORS allowlist for browser clients. Empty (default) mounts no
# CORS middleware, since no browser app calls the MCP endpoint. Set only if one
# is ever added; never use "*" (the endpoint is LAN-bypass authenticated).
# MCP_CORS_ORIGINS=
